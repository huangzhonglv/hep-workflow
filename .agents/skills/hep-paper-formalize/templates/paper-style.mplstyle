# Paper-matching matplotlib style (template).
#
# Copy this file to literature/style/paper-style.mplstyle in your workspace
# project and uncomment / edit values to match the paper you are reproducing.
# Used by scripts/compare_to_reference.py via plt.style.use(...).

# Uncomment and edit to match the paper font family.
# font.family: serif

# Uncomment and edit to match the paper font size.
# font.size: 10

# Uncomment and edit to match axis label size.
# axes.labelsize: 10

# Uncomment and edit to match tick label size.
# xtick.labelsize: 9
# ytick.labelsize: 9

# Uncomment and edit to match line widths.
# lines.linewidth: 1.5

# Uncomment and edit to match marker size.
# lines.markersize: 4

# Uncomment and edit to match axis spine width.
# axes.linewidth: 0.8

# Uncomment and edit to match legend styling.
# legend.frameon: False
# legend.fontsize: 9

# Uncomment and edit to match figure size.
# figure.figsize: 3.4, 2.6

# Uncomment and edit to match the paper color cycle.
# axes.prop_cycle: cycler('color', ['#1f77b4', '#d62728', '#2ca02c', '#9467bd'])
