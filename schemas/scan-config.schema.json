{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "HEP Numerics Scan Configuration",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "analysis_id",
    "model_name",
    "depends_on",
    "scan_parameters",
    "fixed_parameters",
    "observables",
    "constraints_used",
    "figures",
    "seed",
    "parallelism"
  ],
  "properties": {
    "analysis_id": {
      "type": "string",
      "pattern": "^analysis-[0-9]{3}$"
    },
    "model_name": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "depends_on": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "model_version",
        "model_checksum",
        "task_ids"
      ],
      "properties": {
        "model_version": {
          "type": "string",
          "pattern": "^v[0-9]+$"
        },
        "model_checksum": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        },
        "task_ids": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^task-[0-9]{3}$"
          }
        }
      }
    },
    "scan_parameters": {
      "type": "array",
      "minItems": 1,
      "maxItems": 4,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/scan_param"
      }
    },
    "fixed_parameters": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/fixed_param"
      }
    },
    "observables": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/observable_binding"
      }
    },
    "constraints_used": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^c-[0-9]{3}$"
      }
    },
    "figures": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/figure_spec"
      }
    },
    "allow_formula_fallback": {
      "type": "boolean",
      "default": false,
      "description": "Explicit opt-in for task backends whose result-meta calculation_provenance is literature_formula_imported or manual_tree_algebra."
    },
    "seed": {
      "type": "integer",
      "minimum": 0,
      "default": 0,
      "description": "Root seed for the explicit pcg64-v1 local RNG/substream contract."
    },
    "parallelism": {
      "type": "integer",
      "minimum": 1,
      "default": 1,
      "description": "Execution hint that must not change scientific results."
    }
  },
  "$defs": {
    "canonical_name": {
      "type": "string",
      "pattern": "^[A-Za-z_][A-Za-z0-9_]*$",
      "not": {
        "enum": [
          "False", "None", "True", "and", "as", "assert", "async", "await",
          "break", "class", "continue", "def", "del", "elif", "else", "except",
          "finally", "for", "from", "global", "if", "import", "in", "is",
          "lambda", "nonlocal", "not", "or", "pass", "raise", "return", "try",
          "while", "with", "yield"
        ]
      }
    },
    "scan_param": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "canonical_name",
        "range",
        "grid",
        "scale"
      ],
      "properties": {
        "canonical_name": {
          "$ref": "#/$defs/canonical_name"
        },
        "range": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "items": {
            "type": "number"
          }
        },
        "grid": {
          "type": "integer",
          "minimum": 2
        },
        "scale": {
          "enum": [
            "linear",
            "log"
          ]
        }
      }
    },
    "fixed_param": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "canonical_name",
        "value"
      ],
      "properties": {
        "canonical_name": {
          "$ref": "#/$defs/canonical_name"
        },
        "value": {
          "type": "number"
        }
      }
    },
    "observable_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "observable",
        "source"
      ],
      "properties": {
        "observable": {
          "$ref": "#/$defs/canonical_name"
        },
        "source": {
          "oneOf": [
            {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "type",
                "task_id"
              ],
              "properties": {
                "type": {
                  "const": "task"
                },
                "task_id": {
                  "type": "string",
                  "pattern": "^task-[0-9]{3}$"
                }
              }
            },
            {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "type",
                "function",
                "canonical_unit"
              ],
              "properties": {
                "type": {
                  "const": "custom"
                },
                "function": {
                  "$ref": "#/$defs/canonical_name"
                },
                "canonical_unit": {
                  "type": "string",
                  "pattern": "\\S"
                },
                "task_ids": {
                  "type": "array",
                  "minItems": 1,
                  "uniqueItems": true,
                  "items": {
                    "type": "string",
                    "pattern": "^task-[0-9]{3}$"
                  },
                  "description": "Exact calculation backends exposed through the immutable task_outputs context."
                },
                "note": {
                  "type": "string"
                }
              }
            }
          ]
        }
      }
    },
    "figure_spec": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "kind",
            "x",
            "y",
            "constraints"
          ],
          "properties": {
            "kind": {
              "const": "exclusion_2d"
            },
            "x": {
              "$ref": "#/$defs/canonical_name"
            },
            "y": {
              "$ref": "#/$defs/canonical_name"
            },
            "constraints": {
              "type": "array",
              "uniqueItems": true,
              "items": {
                "type": "string",
                "pattern": "^c-[0-9]{3}$"
              }
            },
            "show_allowed_region": {
              "type": "boolean",
              "default": true
            },
            "title": {
              "type": "string"
            },
            "fixed": {
              "type": "object",
              "propertyNames": {
                "$ref": "#/$defs/canonical_name"
              },
              "additionalProperties": {
                "type": "number"
              }
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "kind",
            "x",
            "observables"
          ],
          "properties": {
            "kind": {
              "const": "scan_1d"
            },
            "x": {
              "$ref": "#/$defs/canonical_name"
            },
            "observables": {
              "type": "array",
              "uniqueItems": true,
              "items": {
                "$ref": "#/$defs/canonical_name"
              },
              "minItems": 1
            },
            "overlay_constraint_bands": {
              "type": "boolean",
              "default": true
            },
            "title": {
              "type": "string"
            },
            "fixed": {
              "type": "object",
              "propertyNames": {
                "$ref": "#/$defs/canonical_name"
              },
              "additionalProperties": {
                "type": "number"
              }
            }
          }
        }
      ]
    }
  }
}
