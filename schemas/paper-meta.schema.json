{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "HEP Paper Metadata",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "title",
    "authors",
    "year"
  ],
  "properties": {
    "arxiv": {
      "type": "string",
      "minLength": 1
    },
    "doi": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "authors": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "year": {
      "type": "integer",
      "minimum": 1900
    },
    "journal": {
      "type": "string"
    },
    "version_used": {
      "type": "string"
    },
    "retrieved": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "hash": {
      "type": "string",
      "pattern": "^sha256:.+$"
    }
  },
  "anyOf": [
    {
      "required": [
        "arxiv"
      ]
    },
    {
      "required": [
        "doi"
      ]
    }
  ]
}
