{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "HEP Reproduction Targets",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "paper_id",
    "targets"
  ],
  "properties": {
    "paper_id": {
      "type": "string",
      "minLength": 1
    },
    "targets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/target"
      }
    }
  },
  "$defs": {
    "canonical_name": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_]+$"
    },
    "target_id": {
      "type": "string",
      "pattern": "^[a-zA-Z][a-zA-Z0-9_-]*$"
    },
    "tolerance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "value"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "relative",
            "absolute",
            "qualitative"
          ]
        },
        "value": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        }
      }
    },
    "fixed_value": {
      "anyOf": [
        {
          "type": "number"
        },
        {
          "type": "string"
        },
        {
          "type": "boolean"
        },
        {
          "type": "null"
        }
      ]
    },
    "fixed_parameters": {
      "type": "object",
      "propertyNames": {
        "$ref": "#/$defs/canonical_name"
      },
      "additionalProperties": {
        "$ref": "#/$defs/fixed_value"
      }
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "kind",
        "x_param",
        "y_param",
        "observables",
        "fixed",
        "constraints_in_paper",
        "data_file",
        "tolerance"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/target_id"
        },
        "kind": {
          "type": "string",
          "enum": [
            "formula",
            "benchmark_point",
            "scan_table",
            "figure_curve",
            "exclusion_region"
          ]
        },
        "x_param": {
          "$ref": "#/$defs/canonical_name"
        },
        "y_param": {
          "$ref": "#/$defs/canonical_name"
        },
        "observables": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/canonical_name"
          }
        },
        "fixed": {
          "$ref": "#/$defs/fixed_parameters"
        },
        "constraints_in_paper": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "data_file": {
          "type": "string",
          "minLength": 1
        },
        "tolerance": {
          "$ref": "#/$defs/tolerance"
        },
        "expected_qualitative": {
          "type": "string"
        }
      }
    }
  }
}
