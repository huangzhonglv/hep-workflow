{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "HEP Content-Addressed Dependency Graph",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "verification_status"
  ],
  "properties": {
    "version": {
      "const": "sha256-bytes-v1"
    },
    "verification_status": {
      "type": "string",
      "enum": [
        "verified",
        "legacy-unverified"
      ]
    },
    "entries": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/entry"
      }
    },
    "root_sha256": {
      "$ref": "#/$defs/sha256"
    },
    "reason": {
      "type": "string",
      "pattern": "\\S"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "verification_status": {
            "const": "verified"
          }
        },
        "required": [
          "verification_status"
        ]
      },
      "then": {
        "required": [
          "entries",
          "root_sha256"
        ],
        "not": {
          "required": [
            "reason"
          ]
        }
      },
      "else": {
        "required": [
          "reason"
        ],
        "not": {
          "anyOf": [
            {
              "required": [
                "entries"
              ]
            },
            {
              "required": [
                "root_sha256"
              ]
            }
          ]
        }
      }
    }
  ],
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "safe_path": {
      "type": "string",
      "minLength": 1,
      "allOf": [
        {
          "pattern": "^[^/\\\\]+(?:/[^/\\\\]+)*$"
        },
        {
          "not": {
            "pattern": "(^|/)\\.\\.?(/|$)"
          }
        },
        {
          "not": {
            "pattern": "^[A-Za-z]:/"
          }
        },
        {
          "not": {
            "pattern": "\u0000"
          }
        }
      ]
    },
    "entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scope",
        "role",
        "path",
        "sha256"
      ],
      "properties": {
        "scope": {
          "type": "string",
          "enum": [
            "project",
            "repository"
          ]
        },
        "role": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[^\\s]+$"
        },
        "path": {
          "$ref": "#/$defs/safe_path"
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        }
      }
    }
  }
}
