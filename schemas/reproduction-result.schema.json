{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "HEP Reproduction Result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "repro_id",
    "paper_id",
    "started_at",
    "finished_at",
    "depends_on",
    "input_provenance",
    "run_summary",
    "results"
  ],
  "properties": {
    "repro_id": {
      "type": "string",
      "pattern": "^run-[0-9]{3}$"
    },
    "paper_id": {
      "type": "string",
      "minLength": 1
    },
    "started_at": {
      "$ref": "#/$defs/timestamp"
    },
    "finished_at": {
      "$ref": "#/$defs/timestamp"
    },
    "depends_on": {
      "$ref": "#/$defs/depends_on"
    },
    "input_provenance": {
      "$ref": "#/$defs/dependency_graph"
    },
    "run_summary": {
      "$ref": "#/$defs/run_summary"
    },
    "results": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/target_result"
      }
    },
    "diagnostic_file": {
      "type": "string"
    },
    "notes": {
      "type": "string"
    }
  },
  "$defs": {
    "timestamp": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"
    },
    "checksum": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "target_id": {
      "type": "string",
      "pattern": "^[a-zA-Z][a-zA-Z0-9_-]*$"
    },
    "task_id": {
      "type": "string",
      "pattern": "^task-[0-9]{3}$"
    },
    "target_kind": {
      "type": "string",
      "enum": [
        "formula",
        "benchmark_point",
        "keyed_benchmark_set",
        "scan_table",
        "figure_curve",
        "parametric_curve",
        "exclusion_region"
      ]
    },
    "independence": {
      "type": "string",
      "enum": [
        "independent",
        "independent_manual",
        "tainted",
        "unknown"
      ]
    },
    "tolerance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "value"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "relative",
            "absolute",
            "normalized_distance",
            "qualitative"
          ]
        },
        "value": {
          "anyOf": [
            {
              "type": "number",
              "minimum": 0
            },
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        }
      }
    },
    "file_pair": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "pdf",
        "pdf_sha256",
        "png",
        "png_sha256"
      ],
      "properties": {
        "pdf": {
          "type": "string"
        },
        "pdf_sha256": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        },
        "png": {
          "type": "string"
        },
        "png_sha256": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        }
      }
    },
    "generated_files": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "overlay": {
          "$ref": "#/$defs/file_pair"
        },
        "side_by_side": {
          "$ref": "#/$defs/file_pair"
        },
        "residual": {
          "$ref": "#/$defs/file_pair"
        }
      }
    },
    "metric_value": {
      "type": "number"
    },
    "comparison_completeness": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "complete",
        "match_columns",
        "reference_rows",
        "matched_reference_rows",
        "missing_reference_rows",
        "row_coverage",
        "observables_expected",
        "observables_compared",
        "expected_values",
        "compared_values",
        "value_coverage",
        "blocking_reasons"
      ],
      "properties": {
        "complete": {
          "type": "boolean"
        },
        "match_columns": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "reference_rows": {
          "type": "integer",
          "minimum": 0
        },
        "matched_reference_rows": {
          "type": "integer",
          "minimum": 0
        },
        "missing_reference_rows": {
          "type": "integer",
          "minimum": 0
        },
        "row_coverage": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "observables_expected": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "observables_compared": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "expected_values": {
          "type": "integer",
          "minimum": 0
        },
        "compared_values": {
          "type": "integer",
          "minimum": 0
        },
        "value_coverage": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "blocking_reasons": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "complete": {
                "const": true
              }
            },
            "required": [
              "complete"
            ]
          },
          "then": {
            "properties": {
              "blocking_reasons": {
                "maxItems": 0
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "complete": {
                "const": false
              }
            },
            "required": [
              "complete"
            ]
          },
          "then": {
            "properties": {
              "blocking_reasons": {
                "minItems": 1
              }
            }
          }
        }
      ]
    },
    "comparison": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "metrics"
      ],
      "properties": {
        "kind": {
          "$ref": "#/$defs/target_kind"
        },
        "interpolation_method": {
          "type": "string"
        },
        "geometry_method": {
          "type": "string"
        },
        "completeness": {
          "$ref": "#/$defs/comparison_completeness"
        },
        "metrics": {
          "type": "object",
          "propertyNames": {
            "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
          },
          "additionalProperties": {
            "$ref": "#/$defs/metric_value"
          }
        }
      }
    },
    "provenance_issue": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "state",
        "reason"
      ],
      "allOf": [
        {
          "if": {
            "properties": {
              "reason": {
                "const": "observable_task_unmatched"
              }
            },
            "required": [
              "reason"
            ]
          },
          "then": {
            "required": [
              "observable"
            ]
          },
          "else": {
            "if": {
              "properties": {
                "reason": {
                  "enum": [
                    "reference_independence_unverified",
                    "boundary_provenance_unverified",
                    "synthetic_reference_evidence",
                    "formula_reference_only"
                  ]
                }
              },
              "required": [
                "reason"
              ]
            },
            "else": {
              "required": [
                "task_id"
              ]
            }
          }
        }
      ],
      "properties": {
        "task_id": {
          "$ref": "#/$defs/task_id"
        },
        "observable": {
          "type": "string",
          "minLength": 1
        },
        "state": {
          "type": "string",
          "enum": [
            "manual",
            "tainted",
            "unknown"
          ]
        },
        "reason": {
          "type": "string",
          "enum": [
            "manual_tree_algebra_on_tree_task",
            "literature_formula_imported",
            "benchmark_used_as_input",
            "unsupported_manual_loop",
            "result_meta_missing",
            "result_meta_schema_invalid",
            "derivation_artifacts_unverified",
            "observable_task_unmatched",
            "task_not_in_catalog",
            "benchmark_validation_failed",
            "benchmark_validation_skipped",
            "derivation_evidence_not_runtime_verified",
            "input_provenance_unverified",
            "reference_independence_unverified",
            "boundary_provenance_unverified",
            "synthetic_reference_evidence",
            "formula_reference_only",
            "provenance_blocked"
          ]
        }
      }
    },
    "target_result": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "target_id",
        "tasks_used",
        "derivation_independence",
        "reference_evidence",
        "comparison_evidence",
        "provenance_issues",
        "comparison",
        "tolerance",
        "verdict",
        "verdict_ceiling",
        "generated_files",
        "warnings",
        "notes"
      ],
      "allOf": [
        {
          "if": {
            "properties": {
              "comparison": {
                "properties": {
                  "kind": {"const": "formula"}
                },
                "required": ["kind"]
              }
            },
            "required": ["comparison"]
          },
          "then": {
            "properties": {
              "tolerance": {
                "type": "object",
                "additionalProperties": false,
                "required": ["kind", "value"],
                "properties": {
                  "kind": {"const": "qualitative"},
                  "value": {"type": ["string", "null"]}
                }
              },
              "reference_evidence": {"const": "unverified"},
              "comparison_evidence": {"const": "requires_human_review"},
              "verdict_ceiling": {"const": "needs_human_review"},
              "generated_files": {"maxProperties": 0},
              "comparison": {
                "properties": {
                  "metrics": {"maxProperties": 0}
                },
                "not": {
                  "anyOf": [
                    {"required": ["interpolation_method"]},
                    {"required": ["completeness"]},
                    {"required": ["geometry_method"]}
                  ]
                }
              }
            }
          },
          "else": {
            "properties": {
              "tolerance": {
                "type": "object",
                "additionalProperties": false,
                "required": ["kind", "value"],
                "properties": {
                  "kind": {
                    "type": "string",
                    "enum": ["relative", "absolute", "normalized_distance"]
                  },
                  "value": {"type": "number", "minimum": 0}
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "comparison": {
                "properties": {
                  "kind": {
                    "enum": ["parametric_curve", "exclusion_region"]
                  }
                },
                "required": ["kind"]
              }
            },
            "required": ["comparison"]
          },
          "then": {
            "properties": {
              "tolerance": {
                "properties": {
                  "kind": {"const": "normalized_distance"}
                }
              }
            }
          },
          "else": {
            "if": {
              "properties": {
                "comparison": {
                  "properties": {
                    "kind": {"not": {"const": "formula"}}
                  },
                  "required": ["kind"]
                }
              },
              "required": ["comparison"]
            },
            "then": {
              "properties": {
                "tolerance": {
                  "properties": {
                    "kind": {"enum": ["relative", "absolute"]}
                  }
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "comparison": {
                "properties": {
                  "kind": {
                    "enum": [
                      "scan_table",
                      "keyed_benchmark_set"
                    ]
                  }
                },
                "required": [
                  "kind"
                ]
              }
            },
            "required": [
              "comparison"
            ]
          },
          "then": {
            "properties": {
              "comparison": {
                "required": [
                  "completeness"
                ],
                "not": {
                  "anyOf": [
                    {"required": ["interpolation_method"]},
                    {"required": ["geometry_method"]}
                  ]
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "comparison": {
                "properties": {
                  "kind": {"const": "figure_curve"}
                },
                "required": ["kind"]
              }
            },
            "required": ["comparison"]
          },
          "then": {
            "properties": {
              "comparison": {
                "required": ["interpolation_method"],
                "properties": {
                  "interpolation_method": {
                    "const": "piecewise_linear_union_knots"
                  }
                },
                "not": {
                  "anyOf": [
                    {"required": ["completeness"]},
                    {"required": ["geometry_method"]}
                  ]
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "comparison": {
                "properties": {
                  "kind": {"const": "parametric_curve"}
                },
                "required": ["kind"]
              }
            },
            "required": ["comparison"]
          },
          "then": {
            "properties": {
              "comparison": {
                "required": ["geometry_method"],
                "properties": {
                  "geometry_method": {
                    "const": "normalized_continuous_polyline_hausdorff"
                  }
                },
                "not": {
                  "anyOf": [
                    {"required": ["interpolation_method"]},
                    {"required": ["completeness"]}
                  ]
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "comparison": {
                "properties": {
                  "kind": {
                    "enum": ["benchmark_point", "exclusion_region"]
                  }
                },
                "required": ["kind"]
              }
            },
            "required": ["comparison"]
          },
          "then": {
            "properties": {
              "comparison": {
                "not": {
                  "anyOf": [
                    {"required": ["interpolation_method"]},
                    {"required": ["completeness"]},
                    {"required": ["geometry_method"]}
                  ]
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "comparison": {
                "properties": {
                  "kind": {
                    "enum": [
                      "scan_table",
                      "keyed_benchmark_set"
                    ]
                  }
                },
                "required": [
                  "kind"
                ]
              },
              "verdict": {
                "enum": [
                  "pass",
                  "fail"
                ]
              }
            },
            "required": [
              "comparison",
              "verdict"
            ]
          },
          "then": {
            "properties": {
              "comparison": {
                "required": [
                  "completeness",
                  "metrics"
                ],
                "properties": {
                  "completeness": {
                    "required": [
                      "complete",
                      "missing_reference_rows",
                      "row_coverage",
                      "value_coverage"
                    ],
                    "properties": {
                      "complete": {
                        "const": true
                      },
                      "missing_reference_rows": {
                        "const": 0
                      },
                      "row_coverage": {
                        "const": 1.0
                      },
                      "value_coverage": {
                        "const": 1.0
                      }
                    }
                  },
                  "metrics": {
                    "required": [
                      "max_relative_error",
                      "rms_relative_error",
                      "n_points_compared",
                      "missing_rows"
                    ],
                    "properties": {
                      "max_relative_error": {
                        "type": "number"
                      },
                      "rms_relative_error": {
                        "type": "number"
                      },
                      "max_absolute_error": {
                        "type": "number"
                      },
                      "n_points_compared": {
                        "type": "integer",
                        "minimum": 1
                      },
                      "missing_rows": {
                        "const": 0
                      }
                    }
                  }
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "verdict": {
                "const": "pass"
              }
            },
            "required": [
              "verdict"
            ]
          },
          "then": {
            "properties": {
              "derivation_independence": {
                "const": "independent"
              },
              "reference_evidence": {
                "const": "independent_snapshot"
              },
              "comparison_evidence": {
                "const": "machine_verifiable"
              },
              "verdict_ceiling": {
                "const": "pass"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "derivation_independence": {
                "const": "independent"
              }
            },
            "required": [
              "derivation_independence"
            ]
          },
          "then": {
            "properties": {
              "tasks_used": {
                "minItems": 1
              },
              "provenance_issues": {
                "maxItems": 0
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "derivation_independence": {
                "enum": [
                  "independent_manual",
                  "tainted",
                  "unknown"
                ]
              }
            },
            "required": [
              "derivation_independence"
            ]
          },
          "then": {
            "properties": {
              "provenance_issues": {
                "minItems": 1
              },
              "verdict_ceiling": {
                "const": "needs_human_review"
              }
            }
          }
        },
        {
          "if": {
            "allOf": [
              {
                "properties": {
                  "comparison": {
                    "properties": {
                      "kind": {
                        "not": {
                          "const": "formula"
                        }
                      }
                    },
                    "required": [
                      "kind"
                    ]
                  }
                },
                "required": [
                  "comparison"
                ]
              },
              {
                "properties": {
                  "verdict": {
                    "not": {
                      "const": "blocked"
                    }
                  }
                },
                "required": [
                  "verdict"
                ]
              }
            ]
          },
          "then": {
            "properties": {
              "comparison": {
                "properties": {
                  "metrics": {
                    "minProperties": 1
                  }
                }
              }
            }
          }
        }
      ],
      "properties": {
        "target_id": {
          "$ref": "#/$defs/target_id"
        },
        "tasks_used": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/task_id"
          }
        },
        "derivation_independence": {
          "$ref": "#/$defs/independence"
        },
        "reference_evidence": {
          "type": "string",
          "enum": [
            "independent_snapshot",
            "synthetic",
            "unverified"
          ]
        },
        "comparison_evidence": {
          "type": "string",
          "enum": [
            "machine_verifiable",
            "requires_human_review"
          ]
        },
        "provenance_issues": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/provenance_issue"
          }
        },
        "comparison": {
          "$ref": "#/$defs/comparison"
        },
        "tolerance": {
          "$ref": "#/$defs/tolerance"
        },
        "verdict": {
          "type": "string",
          "enum": [
            "pass",
            "fail",
            "needs_human_review",
            "blocked"
          ]
        },
        "verdict_ceiling": {
          "type": "string",
          "enum": [
            "pass",
            "needs_human_review"
          ]
        },
        "generated_files": {
          "$ref": "#/$defs/generated_files"
        },
        "warnings": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string"
          }
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "model_dependency": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "version",
        "checksum"
      ],
      "properties": {
        "version": {
          "type": [
            "string",
            "null"
          ]
        },
        "checksum": {
          "$ref": "#/$defs/checksum"
        }
      }
    },
    "calculations_dependency": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tasks",
        "model_version"
      ],
      "properties": {
        "tasks": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/task_id"
          }
        },
        "model_version": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "numerics_dependency": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "analysis_id",
        "scan_meta_checksum",
        "scan_csv_checksum"
      ],
      "properties": {
        "analysis_id": {
          "type": "string",
          "pattern": "^analysis-[0-9]{3}$"
        },
        "scan_meta_checksum": {
          "$ref": "#/$defs/checksum"
        },
        "scan_csv_checksum": {
          "$ref": "#/$defs/checksum"
        }
      }
    },
    "literature_dependency": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repro_targets_checksum",
        "paper_extract_checksum",
        "digitized_files_checksums"
      ],
      "properties": {
        "repro_targets_checksum": {
          "$ref": "#/$defs/checksum"
        },
        "paper_extract_checksum": {
          "$ref": "#/$defs/checksum"
        },
        "digitized_files_checksums": {
          "type": "object",
          "propertyNames": {
            "type": "string"
          },
          "additionalProperties": {
            "$ref": "#/$defs/checksum"
          }
        }
      }
    },
    "depends_on": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "model",
        "calculations",
        "numerics",
        "literature"
      ],
      "properties": {
        "model": {
          "$ref": "#/$defs/model_dependency"
        },
        "calculations": {
          "$ref": "#/$defs/calculations_dependency"
        },
        "numerics": {
          "$ref": "#/$defs/numerics_dependency"
        },
        "literature": {
          "$ref": "#/$defs/literature_dependency"
        }
      }
    },
    "dependency_graph": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "version",
        "verification_status"
      ],
      "properties": {
        "version": {
          "const": "sha256-bytes-v1"
        },
        "verification_status": {
          "enum": [
            "verified",
            "legacy-unverified"
          ]
        },
        "entries": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/dependency_entry"
          }
        },
        "root_sha256": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        },
        "reason": {
          "type": "string",
          "pattern": "\\S"
        }
      },
      "oneOf": [
        {
          "properties": {
            "verification_status": {
              "const": "verified"
            }
          },
          "required": [
            "entries",
            "root_sha256"
          ],
          "not": {
            "required": [
              "reason"
            ]
          }
        },
        {
          "properties": {
            "verification_status": {
              "const": "legacy-unverified"
            }
          },
          "required": [
            "reason"
          ],
          "not": {
            "anyOf": [
              {
                "required": [
                  "entries"
                ]
              },
              {
                "required": [
                  "root_sha256"
                ]
              }
            ]
          }
        }
      ]
    },
    "dependency_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scope",
        "role",
        "path",
        "sha256"
      ],
      "properties": {
        "scope": {
          "enum": [
            "project",
            "repository"
          ]
        },
        "role": {
          "type": "string",
          "pattern": "^[^\\s]+$"
        },
        "path": {
          "type": "string",
          "minLength": 1,
          "allOf": [
            {
              "pattern": "^[^/\\\\]+(?:/[^/\\\\]+)*$"
            },
            {
              "not": {
                "pattern": "(^|/)\\.\\.?(/|$)"
              }
            },
            {
              "not": {
                "pattern": "^[A-Za-z]:/"
              }
            },
            {
              "not": {
                "pattern": "\u0000"
              }
            }
          ]
        },
        "sha256": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        }
      }
    },
    "run_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "derivation_independence_aggregate",
        "n_targets_total",
        "n_targets_pass",
        "n_targets_fail",
        "n_targets_needs_human_review",
        "n_targets_blocked"
      ],
      "properties": {
        "derivation_independence_aggregate": {
          "$ref": "#/$defs/independence"
        },
        "n_targets_total": {
          "type": "integer",
          "minimum": 1
        },
        "n_targets_pass": {
          "type": "integer",
          "minimum": 0
        },
        "n_targets_fail": {
          "type": "integer",
          "minimum": 0
        },
        "n_targets_needs_human_review": {
          "type": "integer",
          "minimum": 0
        },
        "n_targets_blocked": {
          "type": "integer",
          "minimum": 0
        }
      }
    }
  }
}
