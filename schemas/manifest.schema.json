{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "HEP Workflow Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "manifest_version",
    "project_name",
    "created",
    "last_updated",
    "active_model_version",
    "artifacts",
    "history"
  ],
  "properties": {
    "manifest_version": {
      "const": 2
    },
    "project_name": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "created": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    },
    "last_updated": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    },
    "active_model_version": {
      "type": [
        "string",
        "null"
      ]
    },
    "artifacts": {
      "$ref": "#/$defs/artifacts"
    },
    "history": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/history_entry"
      }
    }
  },
  "$defs": {
    "status": {
      "type": "string",
      "enum": [
        "not_started",
        "in_progress",
        "partial",
        "done",
        "blocked",
        "failed",
        "skipped"
      ]
    },
    "numerics_status": {
      "type": "string",
      "enum": [
        "not_started",
        "in_progress",
        "partial",
        "done",
        "stale",
        "blocked",
        "failed",
        "skipped"
      ]
    },
    "calculations_status": {
      "type": "string",
      "enum": [
        "not_started",
        "in_progress",
        "partial",
        "done",
        "stale",
        "blocked",
        "failed",
        "skipped"
      ]
    },
    "timestamp": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"
    },
    "checksum": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "history_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "action",
        "timestamp",
        "by"
      ],
      "properties": {
        "action": {
          "type": "string",
          "anyOf": [
            {
              "enum": [
                "idea_complete",
                "model_updated",
                "constraints_complete",
                "constraints_updated",
                "benchmarks_updated",
                "literature_complete",
                "literature_updated",
                "reproduction_run_complete",
                "reproduction_run_failed",
                "numerics_analysis_complete",
                "numerics_analysis_rerun",
                "numerics_figures_regenerated",
                "calculations_updated"
              ]
            },
            {
              "pattern": "^model_complete_v[0-9]+$"
            },
            {
              "pattern": "^calc_task_task-[0-9]{3}_(complete|revised)$"
            }
          ]
        },
        "analysis_id": {
          "type": "string",
          "pattern": "^analysis-[0-9]{3}$",
          "description": "Required on new numerics history events. Legacy events may instead contain one exact analysis_id=<analysis-NNN> note token."
        },
        "event_id": {
          "type": "string",
          "pattern": "^[a-f0-9]{32}$",
          "description": "Required and globally fresh for newly produced numerics and reproduction completion events; legacy history entries may omit it."
        },
        "repro_id": {
          "type": "string",
          "pattern": "^run-[0-9]{3}$"
        },
        "timestamp": {
          "type": "string",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"
        },
        "by": {
          "type": "string"
        },
        "note": {
          "type": "string"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "action": {
                "const": "calculations_updated"
              }
            },
            "required": [
              "action"
            ]
          },
          "then": {
            "required": [
              "note"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "action": {
                "pattern": "^reproduction_run_(complete|failed)$"
              }
            },
            "required": [
              "action"
            ]
          },
          "then": {
            "required": [
              "repro_id"
            ]
          },
          "else": {
            "not": {
              "required": [
                "repro_id"
              ]
            }
          }
        }
      ]
    },
    "idea_artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "files",
        "produced_by",
        "timestamp"
      ],
      "properties": {
        "status": {
          "$ref": "#/$defs/status"
        },
        "files": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string"
          }
        },
        "produced_by": {
          "type": [
            "string",
            "null"
          ]
        },
        "timestamp": {
          "$ref": "#/$defs/timestamp"
        }
      }
    },
    "model_artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "version",
        "files",
        "checksum",
        "produced_by",
        "timestamp"
      ],
      "properties": {
        "status": {
          "$ref": "#/$defs/status"
        },
        "version": {
          "type": [
            "string",
            "null"
          ]
        },
        "files": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string"
          }
        },
        "checksum": {
          "$ref": "#/$defs/checksum"
        },
        "produced_by": {
          "type": [
            "string",
            "null"
          ]
        },
        "timestamp": {
          "$ref": "#/$defs/timestamp"
        }
      }
    },
    "model_dependency": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "version",
        "checksum"
      ],
      "properties": {
        "version": {
          "type": [
            "string",
            "null"
          ]
        },
        "checksum": {
          "$ref": "#/$defs/checksum"
        }
      }
    },
    "calculations_dependency": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tasks",
        "model_version"
      ],
      "properties": {
        "tasks": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^task-[0-9]{3}$"
          }
        },
        "model_version": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "constraints_dependency": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "checksum"
      ],
      "properties": {
        "checksum": {
          "$ref": "#/$defs/checksum"
        }
      }
    },
    "calculations_artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "completed_tasks",
        "pending_tasks",
        "depends_on",
        "produced_by",
        "timestamp"
      ],
      "properties": {
        "status": {
          "$ref": "#/$defs/calculations_status"
        },
        "completed_tasks": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^task-[0-9]{3}$"
          }
        },
        "pending_tasks": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^task-[0-9]{3}$"
          }
        },
        "depends_on": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "model"
          ],
          "properties": {
            "model": {
              "$ref": "#/$defs/model_dependency"
            }
          }
        },
        "produced_by": {
          "type": [
            "string",
            "null"
          ]
        },
        "timestamp": {
          "$ref": "#/$defs/timestamp"
        }
      }
    },
    "constraints_artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "files",
        "depends_on",
        "produced_by",
        "timestamp"
      ],
      "properties": {
        "status": {
          "$ref": "#/$defs/status"
        },
        "files": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string"
          }
        },
        "depends_on": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "model"
          ],
          "properties": {
            "model": {
              "$ref": "#/$defs/model_dependency"
            }
          }
        },
        "produced_by": {
          "type": [
            "string",
            "null"
          ]
        },
        "timestamp": {
          "$ref": "#/$defs/timestamp"
        }
      }
    },
    "numerics_analysis": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "analysis_id",
        "status",
        "files",
        "depends_on",
        "produced_by",
        "timestamp"
      ],
      "properties": {
        "analysis_id": {
          "type": "string",
          "pattern": "^analysis-[0-9]{3}$"
        },
        "status": {
          "$ref": "#/$defs/numerics_status"
        },
        "files": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string"
          }
        },
        "depends_on": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "model",
            "calculations",
            "constraints"
          ],
          "properties": {
            "model": {
              "$ref": "#/$defs/model_dependency"
            },
            "calculations": {
              "$ref": "#/$defs/calculations_dependency"
            },
            "constraints": {
              "$ref": "#/$defs/constraints_dependency"
            }
          }
        },
        "produced_by": {
          "type": "string",
          "minLength": 1
        },
        "timestamp": {
          "type": "string",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"
        }
      }
    },
    "numerics_artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "files",
        "analyses",
        "produced_by",
        "timestamp"
      ],
      "properties": {
        "status": {
          "$ref": "#/$defs/numerics_status"
        },
        "files": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string"
          }
        },
        "analyses": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/numerics_analysis"
          }
        },
        "produced_by": {
          "type": [
            "string",
            "null"
          ]
        },
        "timestamp": {
          "$ref": "#/$defs/timestamp"
        }
      }
    },
    "literature_artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "files",
        "produced_by",
        "timestamp"
      ],
      "properties": {
        "status": {
          "$ref": "#/$defs/status"
        },
        "files": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string"
          }
        },
        "produced_by": {
          "type": [
            "string",
            "null"
          ]
        },
        "timestamp": {
          "$ref": "#/$defs/timestamp"
        }
      }
    },
    "reproduction_artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "runs",
        "depends_on",
        "produced_by",
        "timestamp"
      ],
      "properties": {
        "status": {
          "$ref": "#/$defs/status"
        },
        "runs": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^run-[0-9]{3}$"
          }
        },
        "depends_on": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "model",
            "literature",
            "numerics"
          ],
          "properties": {
            "model": {
              "$ref": "#/$defs/model_dependency"
            },
            "literature": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "checksum"
              ],
              "properties": {
                "checksum": {
                  "$ref": "#/$defs/checksum"
                }
              }
            },
            "numerics": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "analyses"
              ],
              "properties": {
                "analyses": {
                  "type": "array",
                  "uniqueItems": true,
                  "items": {
                    "type": "string",
                    "pattern": "^analysis-[0-9]{3}$"
                  }
                }
              }
            }
          }
        },
        "produced_by": {
          "type": [
            "string",
            "null"
          ]
        },
        "timestamp": {
          "$ref": "#/$defs/timestamp"
        }
      }
    },
    "artifacts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "idea",
        "model",
        "calculations",
        "constraints",
        "numerics"
      ],
      "properties": {
        "idea": {
          "$ref": "#/$defs/idea_artifact"
        },
        "model": {
          "$ref": "#/$defs/model_artifact"
        },
        "calculations": {
          "$ref": "#/$defs/calculations_artifact"
        },
        "constraints": {
          "$ref": "#/$defs/constraints_artifact"
        },
        "numerics": {
          "$ref": "#/$defs/numerics_artifact"
        },
        "literature": {
          "$ref": "#/$defs/literature_artifact"
        },
        "reproduction": {
          "$ref": "#/$defs/reproduction_artifact"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "idea": {
                "properties": {
                  "status": {"const": "done"}
                }
              }
            },
            "required": ["idea"]
          },
          "then": {
            "properties": {
              "idea": {
                "properties": {
                  "files": {"minItems": 1},
                  "produced_by": {"type": "string", "minLength": 1},
                  "timestamp": {"type": "string"}
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "calculations": {
                "properties": {
                  "status": {"const": "stale"}
                }
              }
            },
            "required": ["calculations"]
          },
          "then": {
            "properties": {
              "calculations": {
                "properties": {
                  "completed_tasks": {"minItems": 1},
                  "depends_on": {
                    "properties": {
                      "model": {
                        "properties": {
                          "version": {"type": "string", "minLength": 1},
                          "checksum": {"type": "string"}
                        }
                      }
                    }
                  },
                  "produced_by": {"type": "string", "minLength": 1},
                  "timestamp": {"type": "string"}
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "model": {
                "properties": {
                  "status": {"const": "done"}
                }
              }
            },
            "required": ["model"]
          },
          "then": {
            "properties": {
              "model": {
                "properties": {
                  "version": {"type": "string", "minLength": 1},
                  "files": {"minItems": 1},
                  "checksum": {"type": "string"},
                  "produced_by": {"type": "string", "minLength": 1},
                  "timestamp": {"type": "string"}
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "calculations": {
                "properties": {
                  "status": {"const": "done"}
                }
              }
            },
            "required": ["calculations"]
          },
          "then": {
            "properties": {
              "calculations": {
                "properties": {
                  "completed_tasks": {"minItems": 1},
                  "pending_tasks": {"maxItems": 0},
                  "produced_by": {"type": "string", "minLength": 1},
                  "timestamp": {"type": "string"}
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "constraints": {
                "properties": {
                  "status": {"const": "done"}
                }
              }
            },
            "required": ["constraints"]
          },
          "then": {
            "properties": {
              "constraints": {
                "properties": {
                  "files": {"minItems": 1},
                  "produced_by": {"type": "string", "minLength": 1},
                  "timestamp": {"type": "string"}
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "numerics": {
                "properties": {
                  "status": {"const": "done"}
                }
              }
            },
            "required": ["numerics"]
          },
          "then": {
            "properties": {
              "numerics": {
                "properties": {
                  "files": {"minItems": 1},
                  "analyses": {"minItems": 1},
                  "produced_by": {"type": "string", "minLength": 1},
                  "timestamp": {"type": "string"}
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "literature": {
                "properties": {
                  "status": {"const": "done"}
                }
              }
            },
            "required": ["literature"]
          },
          "then": {
            "properties": {
              "literature": {
                "properties": {
                  "files": {"minItems": 1},
                  "produced_by": {"type": "string", "minLength": 1},
                  "timestamp": {"type": "string"}
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "reproduction": {
                "properties": {
                  "status": {"const": "done"}
                }
              }
            },
            "required": ["reproduction"]
          },
          "then": {
            "properties": {
              "reproduction": {
                "properties": {
                  "runs": {"minItems": 1},
                  "produced_by": {"type": "string", "minLength": 1},
                  "timestamp": {"type": "string"}
                }
              }
            }
          }
        }
      ]
    }
  }
}
