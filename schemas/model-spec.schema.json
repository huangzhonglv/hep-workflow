{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "HEP Model Specification",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "model_name",
    "version",
    "gauge_symmetry",
    "tags",
    "fields",
    "parameters",
    "interactions",
    "conventions"
  ],
  "properties": {
    "model_name": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^v\\d+$"
    },
    "gauge_symmetry": {
      "type": "string"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "fields": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/field"
      }
    },
    "parameters": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/parameter"
      }
    },
    "interactions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/interaction"
      }
    },
    "conventions": {
      "$ref": "#/$defs/conventions"
    },
    "symmetry_breaking": {
      "type": "object",
      "additionalProperties": {
        "type": [
          "string",
          "number",
          "boolean",
          "null"
        ]
      }
    }
  },
  "$defs": {
    "canonical_name": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_]+$"
    },
    "field": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "latex",
        "spin",
        "quantum_numbers",
        "mass_parameter",
        "is_new",
        "propagator_note"
      ],
      "properties": {
        "name": {
          "$ref": "#/$defs/canonical_name"
        },
        "latex": {
          "type": "string"
        },
        "spin": {
          "type": "number"
        },
        "quantum_numbers": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "type": [
              "string",
              "number",
              "integer"
            ]
          }
        },
        "mass_parameter": {
          "anyOf": [
            {
              "$ref": "#/$defs/canonical_name"
            },
            {
              "type": "null"
            }
          ]
        },
        "is_new": {
          "type": "boolean"
        },
        "propagator_note": {
          "type": "string"
        }
      }
    },
    "parameter": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "latex",
        "type",
        "description",
        "unit",
        "role"
      ],
      "properties": {
        "name": {
          "$ref": "#/$defs/canonical_name"
        },
        "latex": {
          "type": "string"
        },
        "type": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "unit": {
          "type": "string"
        },
        "suggested_range": {
          "anyOf": [
            {
              "type": "array",
              "minItems": 2,
              "maxItems": 2,
              "items": {
                "type": "number"
              }
            },
            {
              "type": "null"
            }
          ]
        },
        "value": {
          "type": [
            "number",
            "string"
          ]
        },
        "derivation": {
          "type": "string"
        },
        "source": {
          "type": "string"
        },
        "role": {
          "type": "string",
          "enum": [
            "scan",
            "fixed",
            "derived"
          ]
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "role": {
                "const": "scan"
              }
            }
          },
          "then": {
            "required": [
              "suggested_range"
            ],
            "properties": {
              "suggested_range": {
                "type": "array",
                "minItems": 2,
                "maxItems": 2,
                "items": {
                  "type": "number"
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "role": {
                "const": "derived"
              }
            }
          },
          "then": {
            "required": [
              "derivation"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "role": {
                "const": "fixed"
              }
            }
          },
          "then": {
            "required": [
              "value"
            ]
          }
        }
      ]
    },
    "interaction": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "latex",
        "particles",
        "lorentz_structure",
        "chirality",
        "coupling",
        "feynman_rule_note"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^int-\\d{3}$"
        },
        "latex": {
          "type": "string"
        },
        "particles": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "lorentz_structure": {
          "type": "string"
        },
        "chirality": {
          "type": "string"
        },
        "coupling": {
          "oneOf": [
            {
              "$ref": "#/$defs/canonical_name"
            },
            {
              "type": "string",
              "not": {
                "$ref": "#/$defs/canonical_name"
              }
            }
          ]
        },
        "feynman_rule_note": {
          "type": "string"
        }
      }
    },
    "conventions": {
      "type": "object",
      "additionalProperties": {
        "type": [
          "string",
          "number",
          "boolean"
        ]
      },
      "required": [
        "gauge",
        "momentum_flow",
        "gamma5_scheme",
        "metric_signature"
      ],
      "properties": {
        "gauge": {
          "type": "string"
        },
        "momentum_flow": {
          "type": "string"
        },
        "gamma5_scheme": {
          "type": "string"
        },
        "metric_signature": {
          "type": "string"
        }
      }
    }
  }
}
